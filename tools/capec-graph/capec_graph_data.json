    "standard": "Specific attack methodology with enough detail to understand the approach",
    "detailed": "Concrete attack variant with implementation-level details"
  },
  "relationship_types": {
    "HasMember": "Category/view contains this pattern (view->category, category->meta)",
    "ChildOf": "Pattern is a specialization of a parent (child->parent direction in data, shown as parent->child in edges)",
    "ParentOf": "Inverse of ChildOf",
    "CanPrecede": "This attack can enable or lead to another attack",
    "CanFollow": "Inverse of CanPrecede",
    "PeerOf": "Patterns are related at the same abstraction level",
    "CanAlsoBe": "Pattern can also be viewed as an instance of another"
  },
